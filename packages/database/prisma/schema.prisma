generator client {
  provider = "prisma-client-js"
  output   = "../dist/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model UserConfig {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  userId              String   @unique
  purpose             String
  companyName         String
  teamSize            String
  industry            String
  useCases            String[]
  onboardingCompleted Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum KnowledgeBaseIndexingStatus {
  pending
  indexing
  indexed
  completed
  error
}

model KnowledgeBase {
  id             String                     @id @default(auto()) @map("_id") @db.ObjectId
  userId         String
  fileName       String
  fileSize       Int
  key            String
  indexingStatus KnowledgeBaseIndexingStatus @default(pending)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}