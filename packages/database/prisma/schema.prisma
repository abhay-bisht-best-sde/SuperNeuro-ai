generator client {
  provider = "prisma-client-js"
  output   = "../dist/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
} 

enum IntegrationType {
  GMAIL
  GOOGLE_CALENDAR
  GOOGLE_DRIVE
  GOOGLE_SHEETS
  NOTION
  SLACK
  GOOGLE_DOCS
  YOUTUBE
  REDDIT
}

model Integrations {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  name           IntegrationType @unique
  userConfigIds  String[]     @default([]) @db.ObjectId
  userConfigs    UserConfig[] @relation(fields: [userConfigIds], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserConfig {
  id                  String        @id @default(auto()) @map("_id") @db.ObjectId
  userId              String        @unique
  purpose             String
  companyName         String
  teamSize            String
  industry            String
  useCases            String[]
  integrationIds      String[]      @default([]) @db.ObjectId
  integrations        Integrations[] @relation(fields: [integrationIds], references: [id])
  onboardingCompleted Boolean       @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum KnowledgeBaseIndexingStatus {
  PENDING
  INDEXING
  INDEXED
  ERROR
}

enum ImageProcessingStatus {
  PENDING
  INDEXING
  INDEXED
  ERROR
}

model KnowledgeBase {
  id                  String                     @id @default(auto()) @map("_id") @db.ObjectId
  userId              String
  fileName            String
  fileSize            Int
  key                 String
  indexingStatus      KnowledgeBaseIndexingStatus @default(PENDING)
  embeddingIds        String[]                    @default([])
  imageEmbeddingIds   String[]                    @default([])
  processingAttempts  Int                        @default(0)
  errorMessage        String?
  images              KnowledgeBaseImages[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KnowledgeBaseImages {
  id               String                 @id @default(auto()) @map("_id") @db.ObjectId

  knowledgeBaseId  String                 @db.ObjectId
  knowledgeBase    KnowledgeBase          @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  r2Key            String
  pageNumber       Int
  indexingStatus   ImageProcessingStatus   @default(PENDING)
  textSummary      String?
  embeddingId      String?
  processingAttempts Int                  @default(0)
  errorMessage     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([knowledgeBaseId])
  @@index([indexingStatus])
}

model Conversation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String
  title String

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
}

model Message {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role MessageRole
  content String

  executionStepsWithStatus Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
}