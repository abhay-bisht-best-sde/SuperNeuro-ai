generator client {
  provider = "prisma-client-js"
  output   = "../dist/client"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
} 

enum IntegrationType {
  GMAIL
  GOOGLECALENDAR
  GOOGLEDRIVE
  GOOGLESHEETS
  NOTION
  SLACK
  GOOGLEDOCS
  YOUTUBE
  REDDIT
  TAVILY
  FIRECRAWL
}

model Integrations {
  id   String         @id @default(auto()) @map("_id") @db.ObjectId
  name IntegrationType @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserIntegrationConnection {
  id                       String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                   String
  userConfigId             String  @db.ObjectId
  userConfig               UserConfig @relation(fields: [userConfigId], references: [id])
  provider                 IntegrationType
  connected                Boolean  @default(false)
  composioConnectedAccountId String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@unique([userId, provider])
  @@index([userId])
  @@index([userConfigId])
}

model UserConfig {
  id                       String   @id @default(auto()) @map("_id") @db.ObjectId
  userId                   String   @unique
  purpose                  String
  companyName              String
  teamSize                 String
  industry                 String
  useCases                 String[]
  onboardingCompleted      Boolean  @default(false)
  userIntegrationConnections UserIntegrationConnection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum KnowledgeBaseIndexingStatus {
  PENDING
  INDEXING
  INDEXED
  ERROR
}

enum ImageProcessingStatus {
  PENDING
  INDEXING
  INDEXED
  ERROR
}

model KnowledgeBase {
  id                  String                     @id @default(auto()) @map("_id") @db.ObjectId
  userId              String
  fileName            String
  fileSize            Int
  key                 String
  indexingStatus      KnowledgeBaseIndexingStatus @default(PENDING)
  embeddingIds        String[]                    @default([])
  imageEmbeddingIds   String[]                    @default([])
  processingAttempts  Int                        @default(0)
  errorMessage        String?
  images              KnowledgeBaseImages[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KnowledgeBaseImages {
  id               String                 @id @default(auto()) @map("_id") @db.ObjectId

  knowledgeBaseId  String                 @db.ObjectId
  knowledgeBase    KnowledgeBase          @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  r2Key            String
  pageNumber       Int
  indexingStatus   ImageProcessingStatus   @default(PENDING)
  textSummary      String?
  embeddingId      String?
  processingAttempts Int                  @default(0)
  errorMessage     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([knowledgeBaseId])
  @@index([indexingStatus])
}

enum ConversationType {
  WORKFLOW
  RAG
}

model Conversation {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String
  title String
  type ConversationType @default(WORKFLOW)

  messages Message[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, type])
}

enum MessageRole {
  SYSTEM
  USER
  ASSISTANT
}

model Message {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  conversationId String
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  role MessageRole
  content String

  executionStepsWithStatus Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
}