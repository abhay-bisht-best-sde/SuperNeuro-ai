# Database (Prisma / MongoDB) – shared
DATABASE_URL=

# Clerk (apps/web)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=
NEXT_PUBLIC_CLERK_SIGN_UP_URL=

# OpenAI (LangChain, LlamaIndex)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LangSmith (LLM tracing – smith.langchain.com)
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=superneuro

# Composio (integrations)
COMPOSIO_API_KEY=
# Auth Config IDs from platform.composio.dev
COMPOSIO_AUTH_CONFIG_GMAIL=ac_xxx
COMPOSIO_AUTH_CONFIG_GOOGLE_CALENDAR=ac_xxx
COMPOSIO_AUTH_CONFIG_GOOGLE_DRIVE=ac_xxx
COMPOSIO_AUTH_CONFIG_GOOGLE_SHEETS=ac_xxx
COMPOSIO_AUTH_CONFIG_GOOGLE_DOCS=ac_xxx
COMPOSIO_AUTH_CONFIG_NOTION=ac_xxx
COMPOSIO_AUTH_CONFIG_SLACK=ac_xxx
COMPOSIO_AUTH_CONFIG_YOUTUBE=ac_xxx
COMPOSIO_AUTH_CONFIG_REDDIT=ac_xxx

# Web search (chat tools)
TAVILY_API_KEY=
FIRECRAWL_API_KEY=

# Pinecone (RAG)
PINECONE_API_KEY=
PINECONE_PDF_INDEX_NAME=
PINECONE_IMG_TEXT_INDEX_NAME=

# AWS (SQS – web + worker)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_SQS_PDF_INDEXING_QUEUE_URL=
AWS_SQS_IMAGE_PROCESSING_QUEUE_URL=

# Ably (real-time)
ABLY_API_KEY=

# Redis (conversation cache)
REDIS_URL=

# Cloudflare R2 (file uploads)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_FILES_BUCKET_NAME=
CLOUDFLARE_R2_IMAGES_BUCKET_NAME=

# Worker (optional – defaults in config)
PORT=8000
